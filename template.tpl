___TESTS___

scenarios:
- name: Test - basic conversion fires correctly
  code: |-
    // Mock the sandboxed APIs
    mock('injectScript', function(url, onSuccess, onFailure, cacheKey) {
      // Verify the correct script URL was passed
      assertThat(url).isEqualTo('https://client-conversions.lunio.ai/test-script.js');
      // Simulate successful script load
      onSuccess();
    });

    mock('callInWindow', function(functionName, conversionId, metaData) {
      assertThat(functionName).isEqualTo('LunioTrackConversion');
      assertThat(conversionId).isEqualTo('test-conversion-id');
    });

    runCode({
      scriptUrl: 'https://client-conversions.lunio.ai/test-script.js',
      conversionId: 'test-conversion-id',
      orderId: ''
    });

    assertApi('gtmOnSuccess').wasCalled();
- name: Test 2 — order ID is passed when provided
  code: |-
    mock('injectScript', function(url, onSuccess, onFailure, cacheKey) {
      onSuccess();
    });

    mock('callInWindow', function(functionName, conversionId, metaData) {
      assertThat(metaData).isEqualTo({ order_id: 'order123' });
    });

    runCode({
      scriptUrl: 'https://client-conversions.lunio.ai/test-script.js',
      conversionId: 'test-conversion-id',
      orderId: 'order123'
    });

    assertApi('gtmOnSuccess').wasCalled();
- name: Test 3 — order ID is omitted when blank
  code: |-
    mock('injectScript', function(url, onSuccess, onFailure, cacheKey) {
      onSuccess();
    });

    mock('callInWindow', function(functionName, conversionId, metaData) {
      // metaData should be undefined when orderId is empty
      assertThat(metaData).isUndefined();
    });

    runCode({
      scriptUrl: 'https://client-conversions.lunio.ai/test-script.js',
      conversionId: 'test-conversion-id',
      orderId: ''
    });

    assertApi('gtmOnSuccess').wasCalled();
- name: Test 4 — failure is handled correctly
  code: |-
    mock('injectScript', function(url, onSuccess, onFailure, cacheKey) {
      // Simulate script load failure
      onFailure();
    });

    runCode({
      scriptUrl: 'https://client-conversions.lunio.ai/test-script.js',
      conversionId: 'test-conversion-id',
      orderId: ''
    });

    assertApi('gtmOnFailure').wasCalled();
